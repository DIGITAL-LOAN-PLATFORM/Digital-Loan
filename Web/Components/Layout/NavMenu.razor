<MudStack Spacing="2" Class="nav-root">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="nav-brand">
        <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Filled">DLM</MudAvatar>
        <MudStack Spacing="0" Class="ml-3">
            <MudText Typo="Typo.subtitle1" Class="nav-brand-title">Digital Loan Management</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Operations</MudText>
        </MudStack>
    </MudStack>
﻿<MudNavMenu>
    <div class="d-flex align-center px-4 py-2 nav-section-title rounded-lg mx-2">
        <MudIcon Icon="@Icons.Material.Filled.Home" Color="Color.Primary" Size="Size.Small" Class="mr-2"/>
        <MudText Typo="Typo.subtitle2" Style="font-weight: bold;">Loan Mgnt</MudText>
    </div>
    
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Href="/borrowers" Icon="@Icons.Material.Filled.People">Borrower</MudNavLink>
     <MudNavLink Href="/loans/applications" Icon="@Icons.Material.Filled.People">Loan Application</MudNavLink>
      <MudNavLink Href="/loans/guarantors" Icon="@Icons.Material.Filled.People">Guarantor</MudNavLink>

    <MudDivider />

    <MudNavMenu Dense="true" Class="nav-menu" Color="Color.Primary">

        <MudNavLink Href="/"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Dashboard"
                    Class="nav-link">
            Dashboard
        </MudNavLink>

        <MudDivider Class="my-2" />

        <MudText Typo="Typo.overline" Class="mud-text-secondary px-4 mt-2">Members</MudText>
        <MudNavLink Href="/borrowers"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.People"
                    Class="nav-link">
            Borrowers
        </MudNavLink>

        <MudDivider Class="my-2" />

        <MudText Typo="Typo.overline" Class="mud-text-secondary px-4 mt-2">Loan Setup</MudText>
        <MudNavLink Href="/loanproducts"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.AccountBalance"
                    Class="nav-link">
            Loan Products
        </MudNavLink>
        <MudNavLink Href="/paymentmodality"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Payments"
                    Class="nav-link">
            Payment Modalities
        </MudNavLink>

        <MudDivider Class="my-2" />

        <MudText Typo="Typo.overline" Class="mud-text-secondary px-4 mt-2">Documents</MudText>
        <MudNavLink Href="/documentmanagement"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Description"
                    Class="nav-link">
            Document Management
        </MudNavLink>
        <MudNavLink Href="/requiredocuments"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.FileCopy"
                    Class="nav-link">
            Required Documents
        </MudNavLink>
        <MudNavLink Href="/provideddocuments"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.UploadFile"
                    Class="nav-link">
            Provided Documents
        </MudNavLink>

        <MudDivider Class="my-2" />

        <MudText Typo="Typo.overline" Class="mud-text-secondary px-4 mt-2">Configuration</MudText>
        <MudNavLink Href="/guarantortype"
                    Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.VerifiedUser"
                    Class="nav-link">
            Guarantor Types
        </MudNavLink>

    </MudNavMenu>
</MudStack>