@using Application.DTO
@using Application.Services
@using Domain.Entities
@using MudBlazor

@inject ISnackbar Snackbar
@inject IPaymentModalityService PaymentModalityService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.AddCircle)" Class="mr-2 mb-1"/>
            @(IsEditMode ? "Update Payment Modality" : "Add New Payment Modality")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" 
                                Label="Payment Modality Name" 
                                Required="true" 
                                RequiredError="Modality name is required!"
                                @bind-Value="Model.Modality" 
                                Variant="Variant.Outlined" 
                                Margin="Margin.Normal"/>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="Submit" 
                   Disabled="@_processing">
            @(_processing ? "Processing..." : (IsEditMode ? "Update" : "Save"))
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public int? PaymentModalityId { get; set; }
    [Parameter] public string? InitialModalityValue { get; set; }

    private MudForm? form;
    private bool _processing = false;
    private CreatePaymentModalityDTO Model = new();
    private bool IsEditMode => PaymentModalityId.HasValue && PaymentModalityId.Value != 0;

    protected override void OnInitialized()
    {
        if (IsEditMode)
        {
            Model.Modality = InitialModalityValue ?? "";
        }
    }

    private async Task Submit()
    {
        if (form == null) return;
        
        await form.ValidateAsync();
        if (!form.IsValid) return;

        _processing = true;
        try
        {
            if (IsEditMode)
            {
                // FIXED: Use UpdatePaymentModalityDTO and PaymentModalityService
                var updateDto = new UpdatePaymentModalityDTO { Modality = Model.Modality };
                await PaymentModalityService.UpdatePaymentModalityAsync(PaymentModalityId!.Value, updateDto);
                Snackbar.Add("Payment Modality updated successfully", Severity.Success);
            }
            else
            {
                // FIXED: Call PaymentModalityService
                await PaymentModalityService.CreatePaymentModalityAsync(Model);
                Snackbar.Add("Payment Modality created successfully", Severity.Success);
            }
            
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}