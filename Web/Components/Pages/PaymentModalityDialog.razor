@using Application.DTO
@using Application.Services
@using Domain.Entities
@using MudBlazor

@inject ISnackbar Snackbar
@inject IPaymentModalityService PaymentModalityService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Model.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-2"/>
            @(Model.Id == 0 ? "Add Payment Modality" : "Update Payment Modality")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">
            @* Ensure Model is not null before binding *@
            <MudTextField T="string" Label="Modality Name" @bind-Value="Model.Modality" Required="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance Dialog { get; set; } = null!;
    
    // We keep this as UpdatePaymentModalityDTO because it contains the ID 
    // needed for the Edit scenario.
    [Parameter] public UpdatePaymentModalityDTO Model { get; set; } = new();
    
    private MudForm? form;

    private async Task Submit()
    {
        if (form == null) return;
        await form.Validate();
        if (!form.IsValid) return;

        try 
        {
            if (Model.Id == 0)
            {
                // FIX: Map the data to a CreatePaymentModalityDTO
                var createDto = new CreatePaymentModalityDTO
                {
                    Modality = Model.Modality
                };
                
                await PaymentModalityService.CreatePaymentModalityAsync(createDto);
                Snackbar.Add("Payment modality added", Severity.Success);
            }
            else
            {
                // This stays the same as it already matches the Update method
                await PaymentModalityService.UpdatePaymentModalityAsync(Model.Id, Model);
                Snackbar.Add("Payment modality updated", Severity.Success);
            }
            
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => Dialog.Cancel();
}