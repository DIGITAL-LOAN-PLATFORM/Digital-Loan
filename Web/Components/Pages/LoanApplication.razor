@page "/loans/applications"
@using Application.DTO
@using Application.Interfaces
@inject ILoanApplicationService LoanService
@inject IDialogService DialogService
@inject NavigationManager NavManager
@inject ILoanProductService ProductService 
@inject IPaymentModalityService ModalityService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudPaper Elevation="25" Class="pa-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
            <div>
                <MudText Typo="Typo.h5">Loan Applications</MudText>
                <MudText Typo="Typo.body2">Manage and review all incoming loan requests</MudText>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                New Application
            </MudButton>
        </MudStack>

        <MudTable Items="@Applications" Loading="@_loading" Hover="true" FixedHeader="true" Height="60vh">
            <HeaderContent>
                <MudTh>App #</MudTh>
                <MudTh>Borrower</MudTh>
                <MudTh>Product</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Status</MudTh>
                <MudTh Style="text-align:right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="App #">@context.ApplicationNumber</MudTd>
                <MudTd DataLabel="Borrower">@context.BorrowerName</MudTd>
                <MudTd DataLabel="Product">@context.ProductName</MudTd>
                <MudTd DataLabel="Amount">@context.RequestedAmount.ToString("N0")</MudTd>
                <MudTd DataLabel="Date">@context.DateOfApplication.ToShortDateString()</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                </MudTd>
                <MudTd Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" 
                                   OnClick="@(() => ViewDetails(context.Id))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No applications found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private IEnumerable<LoanApplicationDTO> Applications = new List<LoanApplicationDTO>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            Applications = await LoanService.GetAllApplicationsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private void ViewDetails(int id)
    {
        NavManager.NavigateTo($"/loans/details/{id}");
    }

    private async Task OpenCreateDialog()
    {
        // 1. Fetch the actual data from your services
        var productsEntity = await ProductService.GetAllLoanProductsAsync();
        var modalitiesEntity = await ModalityService.GetAllPaymentModalitiesAsync(); 

        // 2. Map to DTOs for the Dialog parameters
        var productsDto = productsEntity.Select(x => new LoanProductDTO 
        { 
            Id = x.Id, 
            ProductName = x.ProductName 
        }).ToList();

        var modalitiesDto = modalitiesEntity.Select(x => new PaymentModalityDTO 
        { 
            Id = x.Id, 
            Name = x.Modality // Based on your service naming convention
        }).ToList();

        // 3. Prepare the Model
        // Note: You might want to pass a real BorrowerId/Name here from a selection or context
        var newModel = new LoanApplicationDTO 
        { 
            DateOfApplication = DateTime.Now,
            Status = "Pending"
        };

        var parameters = new DialogParameters 
        { 
            ["Model"] = newModel,
            ["Products"] = productsDto,
            ["Modalities"] = modalitiesDto
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        
        var dialog = await DialogService.ShowAsync<LoanApplicationDialog>("Create Loan Application", parameters, options);
        var result = await dialog.Result;
        
        if (!result.Canceled) 
        {
            await LoadData();
        }
    }
}