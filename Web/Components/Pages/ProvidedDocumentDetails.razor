@page "/provideddocuments/{Id:int}"
@using Application.DTO
@using Application.Services.ProvidedDocuments
@using MudBlazor
@inject IProvidedDocumentService ProvidedDocumentService
@inject NavigationManager Navigation

<PageTitle>Provided Document Detail</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    @if (_document == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <div class="d-flex align-center mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoBack"
                           Class="mr-2" />
            <MudText Typo="Typo.h5">Provided Document Detail</MudText>
        </div>

        <MudPaper Elevation="2" Class="pa-6">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Document Name</MudText>
                    <MudText Typo="Typo.body1" Class="mt-1">
                        @(_document.DocumentName ?? "—")
                    </MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Loan Application ID</MudText>
                    <MudText Typo="Typo.body1" Class="mt-1">
                        @_document.IdLoanApplication
                    </MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-3" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Attached Files</MudText>
                    @if (_document.DocumentFiles.Any())
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Class="mt-2">
                            @foreach (var file in _document.DocumentFiles)
                            {
                                <MudChip T="string"
                                         Icon="@Icons.Material.Filled.AttachFile"
                                         Color="Color.Primary">
                                    @file.FileName
                                </MudChip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                            No files attached
                        </MudText>
                    }
                </MudItem>
            </MudGrid>
        </MudPaper>

        <div class="d-flex gap-2 mt-4">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack">
                Back to List
            </MudButton>
        </div>
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }

    private ProvidedDocumentDTO? _document;

    protected override void OnInitialized()
    {
        _document = ProvidedDocumentService.GetProvidedDocumentById(Id);
    }

    private void GoBack() => Navigation.NavigateTo("/provideddocuments");
}