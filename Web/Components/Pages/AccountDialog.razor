@using MudBlazor
@using Application.Interfaces
@using Domain.Entities
@using Domain.ValueObjects
@using Application.DTO
@using Application.Services.Accounts
@inject IAccountService AccountService

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.Name" Label="Account Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.Provider" Label="Provider" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Model.Number" Label="Account Number" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    @* Added T="int" to ensure the select matches the backing field type *@
                    <MudSelect T="int" @bind-Value="_accountTypeValue" Label="Account Type" Required="true" Variant="Variant.Outlined">
                        @foreach (var item in Enum.GetValues<AccountType>())
                        {
                            <MudSelectItem T="int" Value="@((int)item)">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="Model.Balance" Label="Balance" Required="true" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save Account</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance Dialog { get; set; } = null!;
    
    [Parameter] public CreateAccountDTO Model { get; set; } = new();
    [Parameter] public int AccountId { get; set; } = 0;
    [Parameter] public bool IsReadOnly { get; set; } = false;

    private MudForm _form = default!;
    private int _accountTypeValue;

    protected override void OnInitialized()
    {
        // Sync the internal int value with the model type on load
        _accountTypeValue = (int)Model.Type;
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        Model.Type = _accountTypeValue;

        try 
        {
            if (AccountId == 0)
            {
                await AccountService.CreateAccountAsync(Model);
            }
            else
            {
                var updateDto = new UpdateAccountDTO
                {
                    Id = AccountId,
                    Name = Model.Name,
                    Provider = Model.Provider,
                    Number = Model.Number,
                    Type = Model.Type,
                    Balance = Model.Balance
                };
                await AccountService.UpdateAccountAsync(updateDto);
            }
            // Return true so the parent page knows to refresh the list
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (Exception)
        {
            // Ideally, log this or show a local error
            Dialog.Close(DialogResult.Ok(false));
        }
    }

    private void Close() => Dialog.Cancel();
}