@page "/loans/details/{Id:int}"
@using Application.DTO
@using Application.Interfaces
@inject ILoanApplicationService LoanService
@inject IGuarantorService GuarantorService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (Loan == null)
    {
        <MudAlert Severity="Severity.Error">Loan Application not found.</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudCard Elevation="25">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Loan.ApplicationNumber</MudText>
                            <MudChip T="string" Color="@GetStatusColor(Loan.Status)" Size="Size.Small">@Loan.Status</MudChip>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string">
                            <MudListItem Text="@($"Borrower: {Loan.BorrowerName}")" Icon="@Icons.Material.Filled.Person" />
                            <MudListItem Text="@($"Amount: {Loan.RequestedAmount:N0} RWF")" Icon="@Icons.Material.Filled.AttachMoney" />
                            <MudListItem Text="@($"Product: {Loan.ProductName}")" Icon="@Icons.Material.Filled.Category" />
                            <MudListItem Text="@($"Date: {Loan.DateOfApplication.ToShortDateString()}")" Icon="@Icons.Material.Filled.CalendarToday" />
                        </MudList>
                    </MudCardContent>
                    <MudCardActions>
                        @if (Loan.Status == "Pending")
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" Class="ma-1" OnClick="ApproveLoan">Approve</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" Class="ma-1" OnClick="RejectLoan">Reject</MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="8">
                <MudTabs Elevation="25" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
                    
                    <MudTabPanel Text="Guarantors" Icon="@Icons.Material.Filled.Group">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">
                            <MudText Typo="Typo.h6">Loan Guarantors</MudText>
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="AddGuarantor">Add</MudButton>
                        </MudStack>
                        <MudTable Items="@Loan.Guarantors" Hover="true" Dense="true">
                            <HeaderContent>
                                <MudTh>Name</MudTh>
                                <MudTh>ID Number</MudTh>
                                <MudTh>Phone</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>@context.IdentificationNumber</MudTd>
                                <MudTd>@context.Phone</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudTabPanel>

                   <MudTabPanel Text="Documents" Icon="@Icons.Material.Filled.Description">
    <MudGrid>
        @* Left Side: The Requirements based on the Loan Product *@
        <MudItem xs="12" md="5">
            <MudText Typo="Typo.h6" Class="mb-3">Loan Requirements</MudText>
            <MudPaper Outlined="true" Class="pa-4">
                <MudList T="string">
                    @if (Loan.RequiredDocuments != null && Loan.RequiredDocuments.Any())
                    {
                        @foreach (var req in Loan.RequiredDocuments)
                        {
                            var isUploaded = Loan.ProvidedDocuments.Any(d => d.RequiredDocumentId == req.Id);
                            <MudListItem Icon="@(isUploaded ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)" 
                                         IconColor="@(isUploaded ? Color.Success : Color.Default)">
                                <MudText Color="@(isUploaded ? Color.Success : Color.Default)">@req.DocumentName</MudText>
                            </MudListItem>
                        }
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No specific requirements defined for this product.</MudText>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        @* Right Side: The actual uploaded files *@
        <MudItem xs="12" md="7">
            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">
                <MudText Typo="Typo.h6">Provided Document</MudText>
                @* Using your existing Upload Logic button *@
                
            </MudStack>

            <MudTable Items="@Loan.ProvidedDocuments" Hover="true" Dense="true" Elevation="0" Outlined="true">
                <HeaderContent>
                    <MudTh>Document Name</MudTh>
                    <MudTh>File Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.DocumentName</MudTd>
                    <MudTd>@context.FileName</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    </MudGrid>
</MudTabPanel>

                    <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
                        <MudText Typo="Typo.body1">Status: @Loan.Status</MudText>
                        <MudText Typo="Typo.body2">Remarks: @(Loan.ApprovalRemarks ?? Loan.RejectionReason ?? "No remarks yet.")</MudText>
                    </MudTabPanel>

                </MudTabs>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter] public int Id { get; set; }
    private LoanApplicationDTO? Loan;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        Loan = await LoanService.GetApplicationByIdAsync(Id);
        _loading = false;
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private async Task AddGuarantor()
    {
        var parameters = new DialogParameters { ["LoanId"] = Id };
        var dialog = await DialogService.ShowAsync<GuarantorDialog>("Add Guarantor", parameters);
        var result = await dialog.Result;
        if (!result.Canceled) await LoadData();
    }

    private async Task UploadDocument(IBrowserFile file)
    {
        if (file != null)
        {
            // Here you would call your DocumentService.UploadAsync(file, Loan.ApplicationNumber)
            Snackbar.Add($"Uploading {file.Name}...", Severity.Info);
            // After upload, refresh data
            await LoadData();
        }
    }

    private async Task ApproveLoan()
    {
        var result = await LoanService.UpdateApplicationStatusAsync(Id, "Approved", "Meets all criteria");
        if (result) { Snackbar.Add("Loan Approved", Severity.Success); await LoadData(); }
    }

    private async Task RejectLoan()
    {
        var result = await LoanService.UpdateApplicationStatusAsync(Id, "Rejected", "Insufficient collateral");
        if (result) { Snackbar.Add("Loan Rejected", Severity.Warning); await LoadData(); }
    }
}