@page "/requiredocuments"
@using Application.Services.RequiredDocuments
@using Application.DTO
@using MudBlazor
@inject IRequiredDocumentService RequiredDocumentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@using RDEntity = Domain.Entities.RequiredDocument

<PageTitle>Required Documents</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.h4">Required Documents</MudText>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add" 
                   OnClick="@OpenCreateDialog">
            Add New Document
        </MudButton>
    </MudStack>

    <MudPaper Elevation="0" Class="pa-4 mb-4">
        <MudTextField T="string" 
                      Value="@searchTerm" 
                      ValueChanged="@OnSearchChanged"
                      Placeholder="Search by name or type..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      IconSize="Size.Medium" 
                      Class="mt-0" 
                      Immediate="true" />
    </MudPaper>

    <MudDataGrid T="RDEntity"
                 Items="requiredDocuments"
                 Loading="@loading"
                 Hover="true"
                 Striped="true"
                 Dense="true"
                 Elevation="1">
        <Columns>
            <PropertyColumn Property="x => x.DocumentName" Title="Name" />
            <PropertyColumn Property="x => x.DocumentType" Title="Type" />
            <TemplateColumn Title="Actions" CellClass="d-flex justify-end">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                   Color="Color.Info" 
                                   OnClick="@(() => OpenEditDialog(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" 
                                   Color="Color.Default" 
                                   OnClick="@(() => ViewRequiredDocument(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="RDEntity" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<RDEntity> requiredDocuments = new();
    private bool loading = false;
    private string searchTerm = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadRequiredDocuments();
    }

    private async Task OnSearchChanged(string text)
    {
        searchTerm = text;
        await LoadRequiredDocuments();
    }

    private async Task LoadRequiredDocuments()
    {
        loading = true;
        try
        {
            var filter = new FilterRequiredDocumentDTO { SearchTerm = searchTerm };
            requiredDocuments = await RequiredDocumentService.GetAllRequiredDocumentsAsync(filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters { ["IsCreate"] = true, ["CreateModel"] = new CreateRequiredDocumentDTO() };
        var dialog = await DialogService.ShowAsync<RequiredDocumentDialog>("Create Document", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await RequiredDocumentService.CreateRequiredDocumentAsync((CreateRequiredDocumentDTO)result.Data);
            Snackbar.Add("Created successfully", Severity.Success);
            await LoadRequiredDocuments();
        }
    }

    private async Task OpenEditDialog(RDEntity item)
    {
        var dto = new UpdateRequiredDocumentDTO { DocumentName = item.DocumentName, DocumentType = item.DocumentType };
        var parameters = new DialogParameters { ["IsCreate"] = false, ["UpdateModel"] = dto };
        var dialog = await DialogService.ShowAsync<RequiredDocumentDialog>("Edit Document", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await RequiredDocumentService.UpdateRequiredDocumentAsync(item.Id, (UpdateRequiredDocumentDTO)result.Data);
            Snackbar.Add("Updated successfully", Severity.Success);
            await LoadRequiredDocuments();
        }
    }

    private void ViewRequiredDocument(RDEntity item) => Navigation.NavigateTo($"/requiredocuments/{item.Id}");
}