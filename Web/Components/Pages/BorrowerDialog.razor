@using Application.DTO
@using Application.Interface
@using Application.Services
@using Domain.Entities
@using Domain.ValueObjects
@using MudBlazor

@inject ISnackbar Snackbar
@inject ILocationService LocationService
@inject IBorrowerService BorrowerService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(BorrowerId == 0 ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Class="mr-2 mb-1"/>
            @(BorrowerId == 0 ? "Register New Borrower" : "Update Borrower Profile")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="National ID (NIDA)" Required="true" 
                                  @bind-Value="borrowerModel.IdentificationNumber" 
                                  ReadOnly="@(BorrowerId != 0)" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudDatePicker Label="Date of Birth" @bind-Date="_dob" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" Label="Gender" @bind-Value="borrowerModel.Gender" Required="true">
                        <MudSelectItem T="string" Value="@("Male")" />
                        <MudSelectItem T="string" Value="@("Female")" />
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="First Name" @bind-Value="borrowerModel.FirstName" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Last Name" @bind-Value="borrowerModel.LastName" Required="true" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Phone Number" @bind-Value="borrowerModel.PhoneNumber" 
                                  Required="true" Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Phone" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Email Address" @bind-Value="borrowerModel.Email" 
                                  InputType="InputType.Email" Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" Label="Marital Status" @bind-Value="borrowerModel.MaritalStatus" Required="true">
                        <MudSelectItem T="string" Value="@("Single")" />
                        <MudSelectItem T="string" Value="@("Married")" />
                        <MudSelectItem T="string" Value="@("Divorced")" />
                        <MudSelectItem T="string" Value="@("Widowed")" />
                    </MudSelect>
                </MudItem>

                @if (borrowerModel.MaritalStatus == "Married")
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Spouse Name" @bind-Value="borrowerModel.SpouseName" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Spouse NIDA" @bind-Value="borrowerModel.SpouseNidaNumber" />
                    </MudItem>
                }

                <MudItem xs="12"><MudDivider Class="my-2"/></MudItem>

                @* Location Selection *@
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="Province" Value="borrowerModel.HomeLocation?.Province" ValueChanged="OnProvinceChanged" Required="true">
                        @foreach (var p in _provinces)
                        {
                            <MudSelectItem T="string" Value="@p">@p</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="District" Value="borrowerModel.HomeLocation?.District" ValueChanged="OnDistrictChanged" Required="true">
                        @foreach (var d in _districts)
                        {
                            <MudSelectItem T="string" Value="@d">@d</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="Sector" Value="borrowerModel.HomeLocation?.Sector" ValueChanged="OnSectorChanged" Required="true">
                        @foreach (var s in _sectors)
                        {
                            <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@_processing">
            @(_processing ? "Processing..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int BorrowerId { get; set; }

    private MudForm? form;
    private bool _processing = false;
    private Borrower borrowerModel = new() { HomeLocation = new Location() };
    private DateTime? _dob = DateTime.Today.AddYears(-18);

    private List<string> _provinces = new();
    private List<string> _districts = new();
    private List<string> _sectors = new();

    protected override async Task OnInitializedAsync()
    {
        _provinces = await LocationService.GetProvincesAsync();
        if (BorrowerId != 0) 
        {
            // Load existing borrower logic here if needed
        }
    }

    private async Task OnProvinceChanged(string val)
    {
        borrowerModel.HomeLocation.Province = val;
        _districts = await LocationService.GetDistrictsAsync(val);
    }

    private async Task OnDistrictChanged(string val)
    {
        borrowerModel.HomeLocation.District = val;
        _sectors = await LocationService.GetSectorsAsync(val);
    }

    private void OnSectorChanged(string val) => borrowerModel.HomeLocation.Sector = val;

    private async Task Submit()
    {
        await form!.Validate();
        if (!form.IsValid) return;

        _processing = true;
        try
        {
            var dto = new CreateBorrowerDTO
            {
                IdentificationNumber = borrowerModel.IdentificationNumber,
                FirstName = borrowerModel.FirstName,
                LastName = borrowerModel.LastName,
                Email = borrowerModel.Email,
                PhoneNumber = borrowerModel.PhoneNumber,
                Gender = borrowerModel.Gender,
                DOB = _dob ?? DateTime.Now,
                MaritalStatus = borrowerModel.MaritalStatus,
                Location = new LocationDTO 
                { 
                    Province = borrowerModel.HomeLocation.Province,
                    District = borrowerModel.HomeLocation.District,
                    Sector = borrowerModel.HomeLocation.Sector
                }
            };

            await BorrowerService.CreateBorrowerAsync(dto);
            Snackbar.Add("Success", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _processing = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}