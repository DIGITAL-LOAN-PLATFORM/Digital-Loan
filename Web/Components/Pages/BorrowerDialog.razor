@using Application.DTO
@using Application.Interface
@using Domain.Entities
@using Domain.ValueObjects
@using MudBlazor

@inject ISnackbar Snackbar
@inject ILocationService LocationService
@inject IBorrowerService BorrowerService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(borrowerModel.Id == 0 ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Class="mr-2 mb-1"/>
            @(borrowerModel.Id == 0 ? "Register New Borrower" : "Update Borrower Profile")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="National ID (NIDA)" Required="true"
                                  @bind-Value="borrowerModel.IdentificationNumber"
                                  ReadOnly="@(borrowerModel.Id != 0)" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudDatePicker Label="Date of Birth" @bind-Date="borrowerModel.DOB" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" Label="Gender" @bind-Value="borrowerModel.Gender" Required="true">
                        <MudSelectItem T="string" Value="@("Male")" />
                        <MudSelectItem T="string" Value="@("Female")" />
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="First Name" @bind-Value="borrowerModel.FirstName" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Last Name" @bind-Value="borrowerModel.LastName" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Marital Status" @bind-Value="borrowerModel.MaritalStatus" Required="true">
                        <MudSelectItem T="string" Value="@("Single")" />
                        <MudSelectItem T="string" Value="@("Married")" />
                        <MudSelectItem T="string" Value="@("Divorced")" />
                        <MudSelectItem T="string" Value="@("Widowed")" />
                    </MudSelect>
                </MudItem>

                @if (borrowerModel.MaritalStatus == "Married")
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Spouse Name" @bind-Value="borrowerModel.SpouseName" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string" Label="Spouse NIDA" @bind-Value="borrowerModel.SpouseNidaNumber" />
                    </MudItem>
                }

                <MudItem xs="12"><MudDivider Class="my-2"/></MudItem>

                @* Cascading Location Selects — bound directly to flat string fields *@
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Value="borrowerModel.Province" Label="Province"
                               ValueChanged="OnProvinceChanged" ReadOnly="IsReadOnly" Required="true">
                        @foreach (var p in _provinces)
                        {
                            <MudSelectItem Value="@p">@p</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Value="borrowerModel.District" Label="District"
                               ValueChanged="OnDistrictChanged" ReadOnly="IsReadOnly" Required="true"
                               Disabled="@(string.IsNullOrEmpty(borrowerModel.Province))">
                        @foreach (var d in _districts)
                        {
                            <MudSelectItem Value="@d">@d</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Value="borrowerModel.Sector" Label="Sector"
                               ValueChanged="OnSectorChanged" ReadOnly="IsReadOnly" Required="true"
                               Disabled="@(string.IsNullOrEmpty(borrowerModel.District))">
                        @foreach (var s in _sectors)
                        {
                            <MudSelectItem Value="@s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Value="borrowerModel.Cell" Label="Cell"
                               ValueChanged="OnCellChanged" ReadOnly="IsReadOnly" Required="true"
                               Disabled="@(string.IsNullOrEmpty(borrowerModel.Sector))">
                        @foreach (var c in _cells)
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Village" @bind-Value="borrowerModel.Village"
                               ReadOnly="IsReadOnly" Required="true"
                               Disabled="@(string.IsNullOrEmpty(borrowerModel.Cell))">
                        @foreach (var v in _villages)
                        {
                            <MudSelectItem Value="@v">@v</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@_processing">
            @(_processing ? "Processing..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int BorrowerId { get; set; } = 0;
    [Parameter] public bool IsReadOnly { get; set; } = false;

    private MudForm? form;
    private bool _processing = false;

    private Borrower borrowerModel = new();

    private List<string> _provinces = new();
    private List<string> _districts = new();
    private List<string> _sectors   = new();
    private List<string> _cells     = new();
    private List<string> _villages  = new();

    protected override async Task OnInitializedAsync()
    {
        _provinces = await LocationService.GetProvincesAsync();
    }

    private async Task OnProvinceChanged(string val)
    {
        borrowerModel.Province = val;
        borrowerModel.District = null;
        borrowerModel.Sector   = null;
        borrowerModel.Cell     = null;
        borrowerModel.Village  = null;
        _districts.Clear(); _sectors.Clear(); _cells.Clear(); _villages.Clear();

        if (!string.IsNullOrEmpty(val))
            _districts = await LocationService.GetDistrictsAsync(val);

        StateHasChanged();
    }

    private async Task OnDistrictChanged(string val)
    {
        borrowerModel.District = val;
        borrowerModel.Sector   = null;
        borrowerModel.Cell     = null;
        borrowerModel.Village  = null;
        _sectors.Clear(); _cells.Clear(); _villages.Clear();

        if (!string.IsNullOrEmpty(val))
            _sectors = await LocationService.GetSectorsAsync(val);

        StateHasChanged();
    }

    private async Task OnSectorChanged(string val)
    {
        borrowerModel.Sector  = val;
        borrowerModel.Cell    = null;
        borrowerModel.Village = null;
        _cells.Clear(); _villages.Clear();

        if (!string.IsNullOrEmpty(val))
            _cells = await LocationService.GetCellsAsync(val);

        StateHasChanged();
    }

    private async Task OnCellChanged(string val)
    {
        borrowerModel.Cell    = val;
        borrowerModel.Village = null;
        _villages.Clear();

        if (!string.IsNullOrEmpty(val))
            _villages = await LocationService.GetVillagesAsync(val);

        StateHasChanged();
    }

    private async Task Submit()
    {
        if (form == null) return;
        await form.ValidateAsync();
        if (!form.IsValid) return;

        _processing = true;
        try
        {
            if (borrowerModel.Id == 0)
            {
                await BorrowerService.CreateBorrowerAsync(new CreateBorrowerDTO
                {
                    IdentificationNumber = borrowerModel.IdentificationNumber,
                    FirstName            = borrowerModel.FirstName,
                    LastName             = borrowerModel.LastName,
                    Gender               = borrowerModel.Gender,
                    DOB                  = borrowerModel.DOB,
                    MaritalStatus        = borrowerModel.MaritalStatus,
                    SpouseName           = borrowerModel.SpouseName,
                    SpouseNidaNumber     = borrowerModel.SpouseNidaNumber,
                    Province             = borrowerModel.Province,
                    District             = borrowerModel.District,
                    Sector               = borrowerModel.Sector,
                    Cell                 = borrowerModel.Cell,
                    Village              = borrowerModel.Village,
                });
                Snackbar.Add("Borrower registered successfully", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally { _processing = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}